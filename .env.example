# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Admin token for /admin/reload-tokens
MASTER_TOKEN=change-me-strong-random-value

# Storage backend: "local" or "s3"
STORAGE_BACKEND=local

# S3 / DigitalOcean Spaces (required when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=nyc3
S3_PUBLIC_URL=
